# ============================================================
# 🔧 KOSONGIN BACKEND - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================
# Salin file ini ke .env dan isi nilai-nilai sesuai konfigurasi Anda
# ⚠️  JANGAN commit .env ke repository. Gunakan .env.example sebagai template.

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# Format: postgresql://user:password@host:port/database_name
# Contoh lokal: postgresql://postgres:password@localhost:5432/kosongin_dev
# Contoh production: postgresql://user:password@your-host.railway.app:5432/kosongin_prod
DATABASE_URL=postgresql://user:password@localhost:5432/kosongin_dev

# ============================================================
# SERVER CONFIGURATION
# ============================================================
# Port server (default: 3000)
PORT=3000

# Environment: development | staging | production
NODE_ENV=development

# Frontend URL (untuk CORS)
# Development: http://localhost:3000
# Production: https://kosongin.vercel.app
FRONTEND_URL=http://localhost:3000

# ============================================================
# AUTHENTICATION (JWT)
# ============================================================
# Gunakan secret string yang kuat untuk production
# Minimal 32 karakter
JWT_SECRET=your_jwt_secret_key_min_32_characters_for_security

# Token expiry dalam format: 7d (7 hari), 24h (24 jam), 3600 (detik), dll
JWT_EXPIRY=7d

# ============================================================
# CLOUDINARY (IMAGE UPLOAD SERVICE)
# ============================================================
# Setup: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Folder names untuk upload
UPLOAD_CONSUMPTION_FOLDER=consumptions
UPLOAD_CHALLENGE_POSTER_FOLDER=challenges

# ============================================================
# EMAIL SERVICE (RESEND)
# ============================================================
# Setup: https://resend.com
# RESEND_API_KEY: Dapatkan dari Resend dashboard
RESEND_API_KEY=your_resend_api_key

# Email sender (harus verified di Resend)
# Format: noreply@yourdomain.com atau service@kosongin.app
RESEND_SENDER=noreply@kosongin.app

# ============================================================
# ADMIN CONFIGURATION
# ============================================================
# Special code untuk registrasi admin (akses protected)
ADMIN_SPECIAL_CODE=your_super_secret_admin_code

# ============================================================
# CRON JOBS & SCHEDULER
# ============================================================
# Enable/disable automated tasks
# Format: true atau false
ENABLE_DAILY_REMINDER=true
ENABLE_CRON_JOBS=true

# Waktu untuk daily reminder (format: HH:mm)
DAILY_REMINDER_TIME=08:00

# ============================================================
# LOGGING & MONITORING
# ============================================================
# Log level: debug | info | warn | error
LOG_LEVEL=info

# Enable request logging (true untuk development, false untuk production)
ENABLE_REQUEST_LOGGING=true

# ============================================================
# CACHE CONFIGURATION
# ============================================================
# Enable in-memory cache untuk performa
ENABLE_CACHE=true

# Cache TTL dalam menit
CACHE_TTL_MINUTES=60

# ============================================================
# FEATURE FLAGS
# ============================================================
# Enable/disable fitur tertentu untuk testing
ENABLE_SOCIAL_SHARING=true
ENABLE_ANALYTICS=true
ENABLE_EMAIL_VERIFICATION=true

# ============================================================
# CATATAN PENTING (IMPORTANT NOTES)
# ============================================================
# 1. SECURITY
#    - Jangan pernah commit .env ke git repository
#    - Gunakan nilai yang kuat untuk JWT_SECRET di production
#    - Ganti semua placeholder value dengan nilai real
#    - Simpan sensitive data di secret manager (Railway, Vercel, AWS Secrets Manager, dll)
#
# 2. DATABASE SETUP
#    - Pastikan PostgreSQL sudah terinstall dan berjalan
#    - Update DATABASE_URL sesuai dengan config database Anda
#    - Jalankan: npm run db:push untuk setup schema
#    - Opsional: npm run db:seed untuk data dummy
#
# 3. EMAIL SERVICE
#    - Daftar di https://resend.com untuk mendapatkan API key
#    - Verify domain/email Anda di Resend dashboard
#    - RESEND_SENDER harus email yang sudah verified
#
# 4. IMAGE UPLOAD
#    - Daftar di https://cloudinary.com
#    - Dapatkan CLOUDINARY_CLOUD_NAME, API_KEY, dan API_SECRET
#    - Folder names dibuat otomatis oleh Cloudinary
#
# 5. ENVIRONMENT VARIABLES PRIORITY
#    - .env (local development)
#    - .env.local (override untuk specific machine)
#    - Platform env vars (Railway, Vercel, Heroku)
#
# 6. TESTING VARIABLES
#    - Untuk testing, gunakan test database yang terpisah
#    - Update DATABASE_URL ke test database
#    - Jangan gunakan production database untuk testing
#
# 7. PRODUCTION DEPLOYMENT
#    - Pastikan semua environment variables sudah diset di platform hosting
#    - NODE_ENV HARUS 'production' di production
#    - Gunakan strong JWT_SECRET (minimal 32 karakter random)
#    - Enable request logging untuk monitoring
#    - Setup proper CORS dengan FRONTEND_URL yang sesuai